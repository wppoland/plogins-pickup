msgstr "Sicherheitsüberprüfung fehlgeschlagen. Bitte versuche es erneut."

#: src/Service/CheckoutFields.php:104
msgid "Select a date to see available times."
msgstr "Wähle ein Datum aus, um die verfügbaren Zeiten anzuzeigen."

#: src/Service/CheckoutFields.php:105
msgid "No times available on this date. Please choose another."
msgstr ""
"Für dieses Datum sind keine Zeiten verfügbar. Bitte wähle eine andere."

#: src/Service/CheckoutFields.php:106
msgid "Loading times…"
msgstr "Zeiten werden geladen…"

#: src/Service/CheckoutFields.php:107
msgid "Could not load times. Please try again."
msgstr "Zeiten konnten nicht geladen werden. Bitte versuche es erneut."

#: src/Service/CheckoutFields.php:127
msgid ""
"Local pickup is selected but no pickup locations are configured yet. Please "
"contact the store."
msgstr ""
"Lokale Abholung ist ausgewählt, aber es sind noch keine Abholorte "
"konfiguriert. Bitte wende sich an den Shop."

